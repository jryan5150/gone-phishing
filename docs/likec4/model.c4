// Gone-Phishing IRP Engine — Architecture Model
// The LLM is a completion engine, NOT an agent.

specification {
  element actor {
    style {
      shape person
      color amber
    }
  }
  element system {
    style {
      shape rectangle
      color slate
    }
  }
  element component {
    style {
      shape rectangle
      color sky
    }
  }
  element database {
    style {
      shape storage
      color green
    }
  }
  element external {
    style {
      shape rectangle
      color muted
    }
  }

  tag critical
  tag completion-only
  tag graceful-degradation
}

model {

  // ─── Actors ───────────────────────────────────────────────

  technician = actor 'MSP Technician' {
    description 'Reports incidents via chat UI or API call'
  }

  ir_lead = actor 'IR Lead' {
    description 'Receives escalation alerts, coordinates response'
  }

  // ─── Gone-Phishing System ────────────────────────────────

  irp = system 'Gone-Phishing IRP Engine' {
    description 'AI-powered Incident Response Plan engine for MSPs. Deterministic pipeline — not an autonomous agent.'

    ui = component 'Chat UI' {
      description 'Single-file dark-theme web interface. Sends incident description, displays action plan with pipeline status cards.'
      technology 'HTML/JS'
      style {
        shape browser
      }
    }

    api = component 'FastAPI Server' {
      description 'Orchestrates the pipeline. Rate-limited, security-hardened. Each step is an explicit function call — no agent loop.'
      technology 'Python / FastAPI'
    }

    vectordb = database 'ChromaDB' {
      description '11 NIST 800-61 playbooks embedded as vectors. Cosine similarity search returns top 8 matching chunks.'
      technology 'sentence-transformers'
    }

    playbooks = component 'Playbook Files' {
      description 'Phishing, ransomware, data breach, BEC, severity classification, response phases, communication plan, regulatory requirements'
      technology '11 Markdown files'
      style {
        shape queue
      }
    }

    prompt_assembly = component 'Prompt Assembly' {
      description 'Constructs structured prompt from incident description + matched playbook chunks + system instructions. The LLM receives this as read-only input.'
      technology 'Python'
    }

    llm_adapter = component 'LLM Completion' {
      #completion-only
      description 'NOT AN AGENT. Completion engine that receives a structured prompt and returns formatted text. No tools, no memory, no loops, no decisions. BYOM: Claude, GPT-4o, Gemini, Ollama.'
      technology 'BYOM Adapter'
      style {
        color amber
      }
    }

    cw_rest = component 'CW REST Client' {
      #graceful-degradation
      description 'Direct ConnectWise REST API. Creates incident ticket, adds action plan as internal note. Skips cleanly if not configured.'
      technology 'httpx'
    }

    n8n_hook = component 'N8N Webhook' {
      #graceful-degradation
      description 'Fire-and-forget webhook to N8N. Sends incident ID, severity, summary. Returns immediately.'
      technology 'httpx'
    }

    scenarios = database 'Scenario Corpus' {
      description '2,000 generated incident scenarios across 10 categories. Seeded from MITRE ATT&CK. For tabletop exercises and playbook gap analysis.'
      technology 'JSON'
    }
  }

  // ─── External Systems ────────────────────────────────────

  connectwise = external 'ConnectWise Manage' {
    description 'PSA platform. Receives incident tickets with AI-generated action plans as internal notes.'
    technology 'REST API'
  }

  n8n = external 'N8N' {
    description 'Workflow automation. Routes by severity: S1 immediate, S2-S4 standard alert. Email + Teams fan-out.'
    technology 'Webhook'
  }

  llm_provider = external 'LLM Provider' {
    description 'Anthropic Claude, OpenAI GPT-4o, Google Gemini, or Ollama local. Swap with one env var.'
    technology 'HTTPS API'
    style {
      color amber
    }
  }

  // ─── Relationships ───────────────────────────────────────

  // User flow
  technician -> irp.ui 'reports incident'
  ir_lead -> connectwise 'works ticket'

  // UI to API
  irp.ui -> irp.api 'POST /api/incident/respond'

  // Pipeline: search
  irp.api -> irp.vectordb 'semantic search (top 8 chunks)'
  irp.playbooks -> irp.vectordb 'embedded on startup'

  // Pipeline: assembly
  irp.api -> irp.prompt_assembly 'incident + matched chunks'

  // Pipeline: LLM completion (NOT agent tool-use)
  irp.prompt_assembly -> irp.llm_adapter 'structured prompt (read-only, no tools)'
  irp.llm_adapter -> llm_provider 'HTTPS completion request'

  // Pipeline: dispatch
  irp.api -> irp.cw_rest 'create ticket + add plan as note'
  irp.api -> irp.n8n_hook 'fire escalation webhook'
  irp.cw_rest -> connectwise 'REST API calls'
  irp.n8n_hook -> n8n 'fire-and-forget webhook'

  // N8N fan-out
  n8n -> ir_lead 'email / Teams / Slack alert'
}
