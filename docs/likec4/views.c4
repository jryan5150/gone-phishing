// Gone-Phishing — Architecture Views
// Each view is a different zoom level for a different audience.

views {

  // ─── View 1: Landscape (for Klint / leadership) ─────────
  // Shows the system in context: who uses it, what it connects to.

  view landscape {
    title 'IRP Engine — System Context'
    description 'What the system does and what it talks to. The LLM is a completion engine, not an agent.'

    include
      technician,
      ir_lead,
      irp,
      connectwise,
      n8n,
      llm_provider

    style irp {
      color indigo
    }
    style llm_provider {
      color amber
    }
  }

  // ─── View 2: Inside the Engine (for Daniel / IR team) ───
  // Shows every component inside the pipeline.

  view of irp {
    title 'IRP Engine — Internal Architecture'
    description 'Every component and how data flows through the pipeline. Each step is an explicit function call — no agent autonomy.'

    include *

    style llm_adapter {
      color amber
    }
    style cw_rest {
      color green
    }
    style n8n_hook {
      color green
    }
  }

  // ─── View 3: The Pipeline (for technical deep-dive) ─────
  // Focuses on the /api/incident/respond flow specifically.

  view pipeline {
    title 'Incident Pipeline — Step by Step'
    description 'POST /api/incident/respond chains: vector search → prompt assembly → LLM completion → CW ticket → N8N escalation. Each step degrades gracefully.'

    include
      technician,
      ui,
      endpoint_respond,
      vectordb,
      playbooks,
      prompt_assembly,
      llm_adapter,
      llm_provider,
      cw_rest,
      n8n_hook,
      connectwise,
      n8n,
      ir_lead

    style llm_adapter {
      color amber
    }
  }

  // ─── View 4: LLM Boundary (for the "not an agent" conversation) ──
  // Shows exactly what the LLM can and cannot see/do.

  view llm_boundary {
    title 'LLM Boundary — What It Sees vs. What It Touches'
    description 'The LLM receives a structured prompt and returns text. It has no tools, no memory, no agency. It never sees credentials, ticket IDs, or internal systems.'

    include
      prompt_assembly,
      llm_adapter,
      llm_provider

    style llm_adapter {
      color amber
    }
  }

  // ─── View 5: Graceful Degradation ───────────────────────
  // Shows what still works when external services are down.

  view degradation {
    title 'Graceful Degradation'
    description 'Each integration is independent. If CW is down, the plan still generates. If N8N is unreachable, the ticket still gets created.'

    include
      endpoint_respond,
      vectordb,
      prompt_assembly,
      llm_adapter,
      llm_provider,
      cw_rest,
      n8n_hook,
      connectwise,
      n8n

    style cw_rest {
      color green
    }
    style n8n_hook {
      color green
    }
  }
}
