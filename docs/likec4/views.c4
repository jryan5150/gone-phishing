// Gone-Phishing — Architecture Views

views {

  // View 1: System Context (for Klint / leadership)
  view landscape {
    title 'IRP Engine — System Context'
    description 'What the system does and what it connects to'

    include
      technician,
      ir_lead,
      irp,
      connectwise,
      n8n,
      llm_provider
  }

  // View 2: Inside the Engine (for Daniel / IR team)
  view of irp {
    title 'IRP Engine — Internal Architecture'
    description 'Every component and data flow. Each step is an explicit function call — no agent autonomy.'

    include *

    style irp.llm_adapter {
      color amber
    }
  }

  // View 3: Pipeline deep-dive (for technical walkthrough)
  view pipeline {
    title 'Incident Pipeline — Step by Step'
    description 'POST /api/incident/respond chains: vector search, prompt assembly, LLM completion, CW ticket, N8N escalation'

    include
      technician,
      irp.ui,
      irp.api,
      irp.vectordb,
      irp.playbooks,
      irp.prompt_assembly,
      irp.llm_adapter,
      llm_provider,
      irp.cw_rest,
      irp.n8n_hook,
      connectwise,
      n8n,
      ir_lead

    style irp.llm_adapter {
      color amber
    }
  }

  // View 4: LLM Boundary (for the "not an agent" conversation)
  view llm_boundary {
    title 'LLM Boundary — Completion Only'
    description 'The LLM receives a prompt and returns text. No tools, no memory, no agency.'

    include
      irp.prompt_assembly,
      irp.llm_adapter,
      llm_provider

    style irp.llm_adapter {
      color amber
    }
  }

  // View 5: Graceful Degradation
  view degradation {
    title 'Graceful Degradation'
    description 'Each integration is independent. CW down? Plan still generates. N8N unreachable? Ticket still created.'

    include
      irp.api,
      irp.vectordb,
      irp.prompt_assembly,
      irp.llm_adapter,
      llm_provider,
      irp.cw_rest,
      irp.n8n_hook,
      connectwise,
      n8n

    style irp.cw_rest {
      color green
    }
    style irp.n8n_hook {
      color green
    }
  }
}
